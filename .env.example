# Copy this file to .env.local and fill in your MySQL credentials
# Example MySQL connection URL format:
# DATABASE_URL=mysql://user:password@localhost:3306/olbrox_db

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=olbrox_db

# Optional: alternative URL-based configuration
# MYSQL_URL=mysql://root:password@127.0.0.1:3306/olbrox_db
